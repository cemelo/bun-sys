+const EmbedRuntime = struct {
+    vm: *VirtualMachine,
+    global: *JSGlobalObject,
+    event_loop: *EventLoop,
+
+    registrar: ?HandlerRegistrar = null,
+
+    next_promise_id: std.atomic.Value(u64) = std.atomic.Value(u64).init(1),
+    promise_map: std.AutoHashMapUnmanaged(u64, PromiseEntry) = .{},
+    promise_mutex: std.Thread.Mutex = .{},
+
+    invoke_complete_cb: ?InvokeCompleteFn = null,
+    invoke_complete_ctx: ?*anyopaque = null,
+
+    shutdown_requested: std.atomic.Value(bool) = std.atomic.Value(bool).init(false),
+
+    allocator: std.mem.Allocator,
+
+    native_closure_map: std.AutoHashMapUnmanaged(u64, *AsyncNativeClosure) = .{},
+    sync_native_closure_map: std.AutoHashMapUnmanaged(u64, *NativeClosure) = .{},
+    async_jsvalue_closure_map: std.AutoHashMapUnmanaged(u64, *AsyncNativeJsValueClosure) = .{},
+    invoke_closure_map: std.AutoHashMapUnmanaged(u64, *InvokeCompleteClosure) = .{},
+    invoke_callee_map: std.AutoHashMapUnmanaged(u64, u64) = .{},
+
+    const PromiseEntry = struct { value: JSValue };
+};
+
+const HandlerRegistrar = *const fn (
+    kind: [*:0]const u8,
+    name: [*:0]const u8,
+    event_type: ?[*:0]const u8,
+    fn_handle: *anyopaque,
+) callconv(.c) void;
+
+const AsyncNativeFn = *const fn (
+    ctx: ?*anyopaque,
+    promise_id: u64,
+    json_args: [*]const u8,
+    json_args_len: usize,
+) callconv(.c) void;
+
+const NativeFn = *const fn (
+    ctx: ?*anyopaque,
+    global: *anyopaque,
+    args: [*]const u64,
+    argc: usize,
+) callconv(.c) u64;
+
+const AsyncNativeJsValueFn = *const fn (
+    ctx: ?*anyopaque,
+    promise_id: u64,
+    global: *anyopaque,
+    args: [*]const u64,
+    argc: usize,
+) callconv(.c) void;
+
+const InvokeCompleteFn = *const fn (
+    ctx: ?*anyopaque,
+    promise_id: u64,
+    success: c_int,
+    json_result: [*]const u8,
+    json_result_len: usize,
+) callconv(.c) void;
+
+const DestructorFn = *const fn (ctx: ?*anyopaque) callconv(.c) void;
+
+const AsyncNativeClosure = struct {
+    rt: *EmbedRuntime,
+    native_fn: AsyncNativeFn,
+    ctx: ?*anyopaque,
+};
+
+const NativeClosure = struct {
+    rt: *EmbedRuntime,
+    native_fn: NativeFn,
+    ctx: ?*anyopaque,
+    destructor: ?DestructorFn = null,
+};
+
+const AsyncNativeJsValueClosure = struct {
+    rt: *EmbedRuntime,
+    native_fn: AsyncNativeJsValueFn,
+    ctx: ?*anyopaque,
+};
+
+const InvokeCompleteClosure = struct {
+    rt: *EmbedRuntime,
+    promise_id: u64,
+    then_callee: JSValue,
+    catch_callee: JSValue,
+};
+
+const ScheduleCallback = *const fn (ctx: ?*anyopaque) callconv(.c) void;
+
+const ScheduleCtx = struct {
+    callback: ScheduleCallback,
+    user_ctx: ?*anyopaque,
+    allocator: std.mem.Allocator,
+
+    pub fn run(self_ptr: *ScheduleCtx) bun.JSTerminated!void {
+        const self = self_ptr.*;
+        defer self.allocator.destroy(self_ptr);
+        self.callback(self.user_ctx);
+    }
+};
+
+inline fn jsValueKey(value: JSValue) u64 {
+    return @as(u64, @bitCast(@intFromEnum(value)));
+}
+
+inline fn jsValueHandle(value: JSValue) *anyopaque {
+    return @ptrFromInt(@as(usize, @bitCast(@intFromEnum(value))));
+}
+
+inline fn jsValueFromHandle(handle: *anyopaque) JSValue {
+    return JSValue.cast(handle);
+}
+
+inline fn jsValueToRaw(value: JSValue) u64 {
+    return @as(u64, @bitCast(@intFromEnum(value)));
+}
+
+inline fn jsValueFromRaw(raw: u64) JSValue {
+    return @enumFromInt(@as(i64, @bitCast(raw)));
+}
+
+// ---------------------------------------------------------------------------
+// Lifecycle
+// ---------------------------------------------------------------------------
+
+export fn bun_runtime_start(argc: c_int, argv: [*][*:0]u8, out_global: ?*u64) callconv(.c) ?*EmbedRuntime {
+    _ = argc;
+    _ = argv;
+
+    jsc.initialize(false);
+
+    const allocator = bun.default_allocator;
+
+    const vm = VirtualMachine.init(.{
+        .allocator = allocator,
+        .args = std.mem.zeroes(bun.schema.api.TransformOptions),
+        .is_main_thread = true,
+    }) catch return null;
+
+    vm.transpiler.configureDefines() catch return null;
+    vm.loadExtraEnvAndSourceCodePrinter();
+
+    const rt = allocator.create(EmbedRuntime) catch return null;
+    rt.* = .{
+        .vm = vm,
+        .global = vm.global,
+        .event_loop = vm.event_loop,
+        .allocator = allocator,
+    };
+
+    tls_runtime = rt;
+
+    if (out_global) |g| {
+        g.* = jsValueToRaw(vm.global.toJSValue());
+    }
+
+    return rt;
+}
+
+export fn bun_runtime_load_file(rt: ?*EmbedRuntime, path: [*:0]const u8) callconv(.c) c_int {
+    const self = rt orelse return -1;
+    const path_str = bun.String.init(std.mem.span(path));
+    const promise = JSModuleLoader.loadAndEvaluateModule(self.global, &path_str) orelse return -1;
+
+    switch (promise.status()) {
+        .pending => {
+            self.vm.waitForPromise(.{ .internal = promise });
+            return switch (promise.status()) {
+                .fulfilled => 0,
+                .rejected => -1,
+                .pending => -1,
+            };
+        },
+        .fulfilled => return 0,
+        .rejected => return -1,
+    }
+}
+
+export fn bun_runtime_run_event_loop(rt: ?*EmbedRuntime) callconv(.c) c_int {
+    const self = rt orelse return 0;
+    const ctx = self.vm;
+
+    // Mirror Bun CLI's watch-mode event loop (bun.js.zig):
+    //   while (true) {
+    //       while (vm.isEventLoopAlive()) { vm.tick(); eventLoop.autoTickActive(); }
+    //       vm.onBeforeExit();
+    //       eventLoop.tickPossiblyForever();  // blocks until wakeup
+    //   }
+    //
+    // We do one pass of the inner active-tick loop (drains microtasks,
+    // concurrent tasks, AND timers via autoTickActive), then block with
+    // tickPossiblyForever when idle.  Control returns to the Rust caller
+    // after each outer iteration so it can process load requests.
+
+    // Inner loop: drain all ready work including timers.
+    while (ctx.isEventLoopAlive()) {
+        if (self.shutdown_requested.load(.acquire)) return 0;
+        ctx.tick();
+        self.event_loop.autoTickActive();
+    }
+
+    if (self.shutdown_requested.load(.acquire)) return 0;
+
+    // Nothing active — block until something wakes the loop
+    // (bun_runtime_schedule, I/O, timer expiry, etc.).
+    ctx.onBeforeExit();
+    self.event_loop.tickPossiblyForever();
+
+    return if (self.shutdown_requested.load(.acquire)) 0 else 1;
+}
+
+export fn bun_runtime_request_stop(rt: ?*EmbedRuntime) callconv(.c) void {
+    const self = rt orelse return;
+    self.shutdown_requested.store(true, .release);
+    const task = self.allocator.create(ShutdownWakeTask) catch return;
+    task.* = .{ .allocator = self.allocator };
+    self.event_loop.enqueueTaskConcurrent(
+        ConcurrentTask.fromCallback(task, ShutdownWakeTask.callback),
+    );
+}
+
+export fn bun_runtime_stop(rt: ?*EmbedRuntime) callconv(.c) void {
+    const self = rt orelse return;
+
+    {
+        self.promise_mutex.lock();
+        defer self.promise_mutex.unlock();
+
+        var it = self.promise_map.iterator();
+        while (it.next()) |entry| {
+            entry.value_ptr.value.unprotect();
+        }
+        self.promise_map.deinit(self.allocator);
+    }
+
+    {
+        var cit = self.invoke_closure_map.iterator();
+        while (cit.next()) |entry| {
+            self.allocator.destroy(entry.value_ptr.*);
+        }
+        self.invoke_closure_map.deinit(self.allocator);
+    }
+
+    self.invoke_callee_map.deinit(self.allocator);
+
+    {
+        var nit = self.native_closure_map.iterator();
+        while (nit.next()) |entry| {
+            self.allocator.destroy(entry.value_ptr.*);
+        }
+        self.native_closure_map.deinit(self.allocator);
+    }
+
+    {
+        var sit = self.sync_native_closure_map.iterator();
+        while (sit.next()) |entry| {
+            const closure = entry.value_ptr.*;
+            if (closure.destructor) |dtor| {
+                dtor(closure.ctx);
+            }
+            self.allocator.destroy(closure);
+        }
+        self.sync_native_closure_map.deinit(self.allocator);
+    }
+
+    {
+        var ajit = self.async_jsvalue_closure_map.iterator();
+        while (ajit.next()) |entry| {
+            self.allocator.destroy(entry.value_ptr.*);
+        }
+        self.async_jsvalue_closure_map.deinit(self.allocator);
+    }
+
+    tls_runtime = null;
+    self.allocator.destroy(self);
+}
+
+export fn bun_runtime_global(rt: ?*EmbedRuntime) callconv(.c) ?*anyopaque {
+    const self = rt orelse return null;
+    return @ptrCast(self.global);
+}
+
+export fn bun_runtime_schedule(
+    rt: ?*EmbedRuntime,
+    callback: ?ScheduleCallback,
+    ctx: ?*anyopaque,
+) callconv(.c) void {
+    const self = rt orelse return;
+    const cb = callback orelse return;
+
+    const task = self.allocator.create(ScheduleCtx) catch return;
+    task.* = .{ .callback = cb, .user_ctx = ctx, .allocator = self.allocator };
+
+    self.event_loop.enqueueTaskConcurrent(
+        ConcurrentTask.fromCallback(task, ScheduleCtx.run),
+    );
+}
+
+const ShutdownWakeTask = struct {
+    allocator: std.mem.Allocator,
+
+    pub fn callback(self_ptr: *ShutdownWakeTask) bun.JSTerminated!void {
+        self_ptr.allocator.destroy(self_ptr);
+    }
+};
+
+// ---------------------------------------------------------------------------
+// Handler registration
+// ---------------------------------------------------------------------------
+
+export fn bun_runtime_set_registrar(rt: ?*EmbedRuntime, cb: ?HandlerRegistrar) callconv(.c) void {
+    const self = rt orelse return;
+    self.registrar = cb;
+
+    if (cb != null) {
+        const register_fn = JSFunction.create(
+            self.global,
+            bun.String.static("__registerHandler"),
+            registerHandlerHost,
+            4,
+            .{},
+        );
+        self.global.toJSValue().put(self.global, "__registerHandler", register_fn);
+    }
+}
+
+fn registerHandlerHost(global: *JSGlobalObject, callframe: *CallFrame) bun.JSError!JSValue {
+    const self = tls_runtime orelse return .js_undefined;
+    const registrar = self.registrar orelse return .js_undefined;
+
+    const args = callframe.argumentsAsArray(4);
+
+    var kind_buf: [256]u8 = undefined;
+    const kind_slice = jsValueToSlice(args[0], global, &kind_buf) orelse return .js_undefined;
+
+    var name_buf: [256]u8 = undefined;
+    const name_slice = jsValueToSlice(args[1], global, &name_buf) orelse return .js_undefined;
+
+    var et_buf: [256]u8 = undefined;
+    const et_ptr: ?[*:0]const u8 = if (args[2].isUndefinedOrNull())
+        null
+    else
+        if (jsValueToSlice(args[2], global, &et_buf)) |s| s.ptr else null;
+
+    args[3].protect();
+
+    registrar(kind_slice.ptr, name_slice.ptr, et_ptr, jsValueHandle(args[3]));
+
+    return .js_undefined;
+}
+
+// ---------------------------------------------------------------------------
+// Async native functions (JSON-based, legacy)
+// ---------------------------------------------------------------------------
+
+export fn bun_runtime_register_async_native(
+    rt: ?*EmbedRuntime,
+    name: [*:0]const u8,
+    func: ?AsyncNativeFn,
+    ctx: ?*anyopaque,
+) callconv(.c) void {
+    const self = rt orelse return;
+    const native_fn = func orelse return;
+
+    const closure = self.allocator.create(AsyncNativeClosure) catch return;
+    closure.* = .{ .rt = self, .native_fn = native_fn, .ctx = ctx };
+
+    const js_fn = JSFunction.create(
+        self.global,
+        bun.String.init(std.mem.span(name)),
+        asyncNativeHost,
+        1,
+        .{},
+    );
+
+    self.native_closure_map.put(self.allocator, jsValueKey(js_fn), closure) catch {};
+
+    self.global.toJSValue().put(self.global, std.mem.span(name), js_fn);
+}
+
+fn asyncNativeHost(global: *JSGlobalObject, callframe: *CallFrame) bun.JSError!JSValue {
+    const callee = callframe.callee();
+    const self = tls_runtime orelse return .js_undefined;
+    const closure = self.native_closure_map.get(jsValueKey(callee)) orelse return .js_undefined;
+
+    const promise_id = self.next_promise_id.fetchAdd(1, .monotonic);
+
+    const promise = JSInternalPromise.create(global);
+    const promise_val = promise.asValue();
+    promise_val.protect();
+
+    {
+        self.promise_mutex.lock();
+        defer self.promise_mutex.unlock();
+        self.promise_map.put(self.allocator, promise_id, .{ .value = promise_val }) catch {
+            promise_val.unprotect();
+            return .js_undefined;
+        };
+    }
+
+    const args = callframe.argumentsAsArray(1);
+    const json_slice = args[0].toSliceClone(global) catch {
+        promise_val.unprotect();
+        self.promise_mutex.lock();
+        defer self.promise_mutex.unlock();
+        _ = self.promise_map.fetchRemove(promise_id);
+        return .js_undefined;
+    };
+    defer json_slice.deinit();
+
+    closure.native_fn(closure.ctx, promise_id, json_slice.ptr, json_slice.len);
+
+    return promise_val;
+}
+
+// ---------------------------------------------------------------------------
+// Sync native functions (JSValue-based)
+// ---------------------------------------------------------------------------
+
+export fn bun_runtime_register_native(
+    rt: ?*EmbedRuntime,
+    name: [*:0]const u8,
+    func: ?NativeFn,
+    ctx: ?*anyopaque,
+    destructor: ?DestructorFn,
+) callconv(.c) void {
+    const self = rt orelse return;
+    const native_fn = func orelse return;
+
+    const closure = self.allocator.create(NativeClosure) catch return;
+    closure.* = .{ .rt = self, .native_fn = native_fn, .ctx = ctx, .destructor = destructor };
+
+    const js_fn = JSFunction.create(
+        self.global,
+        bun.String.init(std.mem.span(name)),
+        syncNativeHost,
+        8,
+        .{},
+    );
+
+    self.sync_native_closure_map.put(self.allocator, jsValueKey(js_fn), closure) catch {};
+
+    self.global.toJSValue().put(self.global, std.mem.span(name), js_fn);
+}
+
+fn syncNativeHost(global: *JSGlobalObject, callframe: *CallFrame) bun.JSError!JSValue {
+    const callee = callframe.callee();
+    const self = tls_runtime orelse return .js_undefined;
+    const closure = self.sync_native_closure_map.get(jsValueKey(callee)) orelse return .js_undefined;
+
+    const raw_args = callframe.argumentsAsArray(8);
+    var raw_vals: [8]u64 = undefined;
+    var argc: usize = 0;
+    for (raw_args) |arg| {
+        if (arg == .zero) break;
+        raw_vals[argc] = jsValueToRaw(arg);
+        argc += 1;
+    }
+
+    const result_raw = closure.native_fn(closure.ctx, @ptrCast(global), &raw_vals, argc);
+    return jsValueFromRaw(result_raw);
+}
+
+// ---------------------------------------------------------------------------
+// Async native functions (JSValue-based)
+// ---------------------------------------------------------------------------
+
+export fn bun_runtime_register_async_native_jsvalue(
+    rt: ?*EmbedRuntime,
+    name: [*:0]const u8,
+    func: ?AsyncNativeJsValueFn,
+    ctx: ?*anyopaque,
